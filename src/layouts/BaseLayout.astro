---
import "../styles/global.css";
const { title = "Zararsız Yaşam — Melis Zararsız", description = "Mindfulness temelli koçluk, yin yoga ve meditasyon ekseninde bilinçli bir yaşam için çalışmalar, yazılar ve buluşmalar." } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="tr">
<head>
<script is:inline>document.documentElement.className='js'</script>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,500&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>
<header>
  <div class="wrap nav">
    <a class="brand" href={base} aria-label="Zararsız Yaşam">
      <img class="brand-logo" src={`${base}assets/img/logo.jpeg`} alt="Zararsız Yaşam">
    </a>
    <nav>
      <ul class="menu" id="menu">
        <li><a href={`${base}hakkimda/`}>Hakkımda</a></li>
        <li><a href={`${base}birlikte-calisalim/`}>Birlikte Çalışalım</a></li>
        <li><a href={`${base}bulusmalar/`}>Buluşmalar</a></li>
        <li><a href={`${base}blog/`}>Blog Yazıları</a></li>
        <li><a href={`${base}kitap/`}>Kitap</a></li>
        <li><a href={`${base}iletisim/`}>İletişim</a></li>
      </ul>
    </nav>
    <button class="burger" id="burger" aria-label="Menü"><span></span><span></span><span></span></button>
  </div>
</header>
<main>
<slot />
</main>
<footer>
  <div class="news">
    <div class="wrap news-grid">
      <div>
        <h2>Haberlerde Buluşalım</h2>
        <p>Yeni yazılar, buluşmalar ve gelişmelerden ilk sen haberdar ol.</p>
      </div>
      <form onsubmit="return false">
        <input type="email" placeholder="E-posta adresiniz" aria-label="E-posta adresiniz">
        <button class="btn btn-primary" type="submit">Kaydol</button>
      </form>
    </div>
  </div>
  <div class="wrap foot">
    <div>
      <a class="brand logo-chip" href={base} aria-label="Zararsız Yaşam">
        <img class="brand-logo" src={`${base}assets/img/logo.jpeg`} alt="Zararsız Yaşam">
      </a>
      <p style="color:#D8C2B4;margin-top:14px;max-width:26em">Mindfulness, meditasyon ve yin yoga ekseninde bilinçli bir yaşam için.</p>
      <p class="tagline">Kendine yaklaştıkça, hayat da sana yaklaşır.</p>
    </div>
    <div class="foot-col">
      <h4>Hızlı Erişim</h4>
      <ul>
        <li><a href={`${base}hakkimda/`}>Hakkımda</a></li>
        <li><a href={`${base}birlikte-calisalim/`}>Birlikte Çalışalım</a></li>
        <li><a href={`${base}bulusmalar/`}>Buluşmalar</a></li>
        <li><a href={`${base}blog/`}>Blog Yazıları</a></li>
        <li><a href={`${base}kitap/`}>Kitap</a></li>
      </ul>
    </div>
    <div class="foot-col">
      <h4>İletişim</h4>
      <ul>
        <li><a href="mailto:ben@meliszararsiz.com">ben@meliszararsiz.com</a></li>
        <li>Instagram · @zararsiz_yasam</li>
        <li>Spotify · Zararsız Yaşam</li>
        <li>YouTube · Zararsız Yaşam</li>
      </ul>
      <div class="social">
        <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        <a href="#" aria-label="Spotify"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M7.5 10c3-1 6-.6 8.5.8M8 13c2.3-.7 4.7-.4 6.7.7M8.5 16c1.7-.5 3.5-.3 5 .5"/></svg></a>
        <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3"/><path d="M11 9.5l4 2.5-4 2.5z" fill="currentColor" stroke="none"/></svg></a>
        <a href="#" aria-label="E-posta"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg></a>
      </div>
    </div>
  </div>
  <div class="legal">© 2026 Zararsız Yaşam · Melis Zararsız</div>
</footer>
<script is:inline>
document.documentElement.className='js'
</script>
</body>
</html>
